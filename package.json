{
  "name": "@diegopetrucci/pi-intercom",
  "version": "0.6.1",
  "description": "Local session-to-session intercom extension for Pi coding agent and tlh workflows.",
  "license": "MIT",
  "type": "module",
  "main": "index.ts",
  "files": [
    "index.ts",
    "types.ts",
    "config.ts",
    "profile.ts",
    "reply-tracker.ts",
    "broker/**/*.ts",
    "ui/**/*.ts",
    "skills/**/*"
  ],
  "scripts": {
    "test": "tsx --test broker/paths.test.ts broker/spawn.test.ts profile.test.ts reply-tracker.test.ts intercom.integration.test.ts test/inline-message.test.ts"
  },
  "keywords": [
    "pi-package"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diegopetrucci/pi-intercom.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "dependencies": {
    "tsx": "^4.20.0",
    "typebox": "^1.1.24"
  }
}
